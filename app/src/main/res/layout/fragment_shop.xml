<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep"
    android:padding="16dp"
    android:paddingBottom="80dp">

    <FrameLayout
        android:id="@+id/petContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="340dp"
        app:layout_constraintWidth_percent="0.85">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.5"
            android:background="@drawable/pet_glow" />

        <ImageView
            android:id="@+id/imagePet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/catInClothes"
            android:scaleType="fitCenter"
            android:src="@drawable/pet_default" />
    </FrameLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardClothing"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@color/bg_surface"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/petContainer"
        app:layout_constraintWidth_max="380dp"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPrev"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/left"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@android:drawable/ic_media_previous"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="28dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="8dp">

                <TextView
                    android:id="@+id/textName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:maxLines="1"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    tools:text="Зелёный костюм" />

                <TextView
                    android:id="@+id/textPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/coin_gold"
                    android:textSize="13sp"
                    tools:text="Цена: 30 монет" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonNext"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/right"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@android:drawable/ic_media_next"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="28dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/bottomActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_max="380dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonAction"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:letterSpacing="0"
            android:textAllCaps="false"
            android:textSize="15sp"
            tools:text="Купить за 30 монет" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
